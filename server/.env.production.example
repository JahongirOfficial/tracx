# Production environment for tracx.biznesjon.uz
# Copy to .env and fill in real values:
#   cp .env.production.example .env

PORT=5001
NODE_ENV=production

# PostgreSQL — matches docker-compose.prod.yml (host port 5433)
DATABASE_URL=postgresql://tracx_user:YOUR_DB_PASSWORD@localhost:5433/tracx?schema=public

# Redis — matches docker-compose.prod.yml (host port 6380)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6380

# JWT — use long random strings (openssl rand -hex 64)
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_STRING
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SuperAdmin credentials
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Currency
DEFAULT_USD_RATE=12800

# CORS — production domain only
CORS_ORIGINS=https://tracx.biznesjon.uz

# Trial period (days)
TRIAL_DAYS=7

# Payme Business API
PAYME_MERCHANT_ID=69874b603ae533b283c2aa8f
# Production key (get from Payme merchant cabinet)
PAYME_KEY=YOUR_PAYME_PRODUCTION_KEY
